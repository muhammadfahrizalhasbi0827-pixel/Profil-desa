# 1. Mencegah pengguna melihat daftar file di dalam folder (Directory Browsing)
Options -Indexes

# 2. Proteksi dari Clickjacking (Mencegah web di-frame oleh situs lain)
Header always set X-Frame-Options "DENY"

# 3. Mencegah browser menebak jenis file (Mencegah MIME-sniffing)
Header always set X-Content-Type-Options "nosniff"

# 4. Kebijakan Keamanan Konten (Content Security Policy) dasar
Header always set Content-Security-Policy "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; frame-ancestors 'none';"

# 5. Mencegah pengiriman informasi referer ke situs luar
Header always set Referrer-Policy "no-referrer"
